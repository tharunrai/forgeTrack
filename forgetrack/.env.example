# ==============================================
# ForgeTrack Environment Variables
# ==============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ==============================================

# ----- Supabase (REQUIRED) -----
# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (safe for frontend)
VITE_SUPABASE_ANON_KEY=...

# Supabase service role key (ONLY for seed scripts & Edge Functions, NEVER in frontend)
SUPABASE_SERVICE_ROLE_KEY=...

# ----- AI Integration (OPTIONAL) -----
# GitHub Models token (for AI-powered CSV column mapping)
VITE_GITHUB_TOKEN=

# OpenRouter API key (alternative AI provider)
VITE_OPENROUTER_API_KEY=
